@page "/EditNewsPage/{id:int}"
@page "/AddNewsPage"
@using Application.Dto
@using Application.Interfaces.service
@rendermode InteractiveServer
@inject INewsServices newsServices
@inject NavigationManager Navigation


<h5 class="mb-0">@(isEditMode ? "ویرایش کاربر" : "ثبت کاربر")</h5>


<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">ویرایش کاربر</h5>
                </div>

                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="model" OnSubmit="Save">
                            <div class="mb-3">
                                <label class="form-label">  عنوان </label>
                                <InputText class="form-control" @bind-Value="model.Title" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">  متن </label>
                                <InputText class="form-control" @bind-Value="model.Description" />
                            </div>



                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    ذخیره تغییرات
                                </button>

                                <button type="button" class="btn btn-secondary" @onclick="BackToList">
                                    انصراف
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    [Parameter]
    public int id { get; set; }
    bool isLoading = true;
    bool isEditMode = true;
    NewsDto model = new NewsDto();
    protected override async Task OnInitializedAsync()
    {
        if (id ==0)
        {

        }
        else
        {
            model =await newsServices.GetNewsById(id);

        }
        isLoading = false;

    }

    protected async void Save()
    {
        if (id == 0)
        {
            model.UserId = 1;
            var res =await newsServices.CreatNews(model);
            if (res > 0)
            {
                Navigation.NavigateTo("/NewsPage");
            }
        }
        else
        {
            var res =await newsServices.UpdateNews(model);
            if (res > 0)
        {
            Navigation.NavigateTo("/NewsPage");
        }
           
        }
        
        
    }

    protected void BackToList()
    {
        Navigation.NavigateTo("/NewsPage");
    }
}
